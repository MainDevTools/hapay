<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Hapay.Views.DetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="ThisPage"
    xmlns:vm="clr-namespace:Hapay.ViewModels"
    xmlns:models="clr-namespace:Hapay.Models"
    xmlns:conv="clr-namespace:Hapay.Converters"
    x:DataType="vm:DetailViewModel"
    Title="{Binding Item.Store}">

    <ContentPage.Resources>
        <conv:StringNotEmptyConverter x:Key="NotEmpty" />
        <conv:InvertBoolConverter x:Key="Invert" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Image Source="{Binding Item.ImageUrl}" Aspect="AspectFit" HeightRequest="200" />

            <Label Text="{Binding Item.Title}" FontSize="18" FontAttributes="Bold" />
            <Label Text="{Binding Item.VariantNote}" TextColor="Gray"
                   IsVisible="{Binding Item.VariantNote, Converter={StaticResource NotEmpty}}" />

            <!-- ціна: ДІАПАЗОН по крамницях згори (§17) — «5 999 – 6 499 ₴» або одна ціна -->
            <Label Text="{Binding PriceRangeText}" FontSize="24" FontAttributes="Bold" />

            <!-- «Наявно в N крамницях» одразу під ціною; деталі — блок «Де купити» нижче -->
            <Label Text="{Binding OffersLine}" FontAttributes="Bold" FontSize="13"
                   TextColor="{AppThemeBinding Light=#512BD4, Dark=#AC99EA}"
                   IsVisible="{Binding HasOffers}" />

            <!-- одна крамниця зі знижкою → класичне «стара ціна + −%» (для діапазону зайве) -->
            <HorizontalStackLayout Spacing="8" IsVisible="{Binding ShowSingleDiscount}">
                <Label Text="{Binding Item.OldGrn}" FontSize="15" TextColor="Gray"
                       TextDecorations="Strikethrough" VerticalOptions="Center" />
                <Border BackgroundColor="#E23B3B" Padding="7,3" StrokeThickness="0"
                        StrokeShape="RoundRectangle 7" VerticalOptions="Center">
                    <Label Text="{Binding Item.PctText}" TextColor="White" FontAttributes="Bold" FontSize="12" />
                </Border>
            </HorizontalStackLayout>

            <Label Text="Історія ціни" FontAttributes="Bold" TextColor="Gray" Margin="0,12,0,0" />
            <ActivityIndicator IsRunning="{Binding LoadingHistory}" IsVisible="{Binding LoadingHistory}"
                               HorizontalOptions="Start" />
            <Label Text="{Binding HistoryNote}" TextColor="Gray"
                   IsVisible="{Binding HistoryNote, Converter={StaticResource NotEmpty}}" />
            <GraphicsView x:Name="Chart" HeightRequest="180" />

            <!-- «Де купити» (T15/§17.5): той самий товар (mpn) у крамницях, від найдешевшої.
                 Видно лише коли є ≥2 крамниці — інакше блок не додає нічого. -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding HasOffers}" Margin="0,12,0,0">
                <Label Text="Де купити" FontAttributes="Bold" TextColor="Gray" />
                <VerticalStackLayout Spacing="6" BindableLayout.ItemsSource="{Binding Offers}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:Offer">
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="12,10"
                                    BackgroundColor="{AppThemeBinding Light=#F4F4F6, Dark=#22242A}"
                                    Opacity="{Binding Opacity}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.OpenOfferCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Store}" FontAttributes="Bold" />
                                        <Label Text="Немає в наявності" FontSize="11" TextColor="Gray"
                                               IsVisible="{Binding InStock, Converter={StaticResource Invert}}" />
                                    </VerticalStackLayout>
                                    <!-- ціна крамниці як згори картки: поточна + −% в рядок, стара перекреслена під ними -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="1" HorizontalOptions="End">
                                        <HorizontalStackLayout Spacing="6" HorizontalOptions="End">
                                            <Label Text="{Binding CurrentGrn}" FontAttributes="Bold"
                                                   FontSize="16" VerticalOptions="Center" />
                                            <Border BackgroundColor="#E23B3B" Padding="5,2" StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 6" VerticalOptions="Center"
                                                    IsVisible="{Binding HasPct}">
                                                <Label Text="{Binding PctText}" TextColor="White"
                                                       FontAttributes="Bold" FontSize="10" />
                                            </Border>
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding OldGrn}" FontSize="12" TextColor="Gray"
                                               TextDecorations="Strikethrough" HorizontalOptions="End"
                                               IsVisible="{Binding HasOld}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Button Text="Відкрити в крамниці" Command="{Binding OpenStoreCommand}"
                    Margin="0,12,0,0" HeightRequest="48" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
