<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Hapay.Views.DetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="ThisPage"
    xmlns:vm="clr-namespace:Hapay.ViewModels"
    xmlns:models="clr-namespace:Hapay.Models"
    xmlns:conv="clr-namespace:Hapay.Converters"
    x:DataType="vm:DetailViewModel"
    Title="{Binding PageTitle}">

    <ContentPage.Resources>
        <conv:StringNotEmptyConverter x:Key="NotEmpty" />
        <conv:InvertBoolConverter x:Key="Invert" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Фото на власній білій поверхні, а не «в повітрі»: у стрічці й каталозі
                 воно теж на білому, тож перехід у картку не міняє вигляд товару. -->
            <Border Style="{StaticResource Thumb}" Padding="12" HeightRequest="220">
                <Image Source="{Binding Item.ImageUrl}" Aspect="AspectFit" />
            </Border>

            <Label Text="{Binding Item.Title}" Style="{StaticResource H1}" FontSize="18" />
            <Label Text="{Binding Item.VariantNote}" Style="{StaticResource Caption}"
                   IsVisible="{Binding Item.VariantNote, Converter={StaticResource NotEmpty}}" />

            <!-- ціна: ДІАПАЗОН по крамницях згори (§17) — «5 999 – 6 499 ₴» або одна ціна -->
            <Label Text="{Binding PriceRangeText}" Style="{StaticResource H1}" FontSize="26" />

            <!-- «Наявно в N крамницях» одразу під ціною; деталі — блок «Де купити» нижче -->
            <Label Text="{Binding OffersLine}" FontAttributes="Bold" FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource BrandLight}, Dark={StaticResource BrandDark}}"
                   IsVisible="{Binding HasOffers}" />

            <!-- одна крамниця зі знижкою → класичне «стара ціна + −%» (для діапазону зайве) -->
            <HorizontalStackLayout Spacing="8" IsVisible="{Binding ShowSingleDiscount}">
                <Label Text="{Binding Item.OldGrn}" Style="{StaticResource PriceOld}"
                       FontSize="15" VerticalOptions="Center" />
                <Border Style="{StaticResource PillDiscount}" Padding="7,3" VerticalOptions="Center">
                    <Label Text="{Binding Item.PctText}" TextColor="White" FontAttributes="Bold" FontSize="12" />
                </Border>
            </HorizontalStackLayout>

            <!-- «Знижка нічого не дає» — на картці особливо доречно: одразу під нею блок
                 «Де купити» показує ті самі крамниці з тією самою ціною, тож людина
                 бачить не наше твердження, а докази. -->
            <Border IsVisible="{Binding Item.HasSamePrice}" HorizontalOptions="Start"
                    Style="{StaticResource PillWarn}" Padding="10,6">
                <Label Text="{Binding Item.SamePriceText}" FontSize="13" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource WarnFgLight}, Dark={StaticResource WarnFgDark}}" />
            </Border>

            <Label Text="Історія ціни" Style="{StaticResource H2}" Margin="0,12,0,0" />
            <ActivityIndicator IsRunning="{Binding LoadingHistory}" IsVisible="{Binding LoadingHistory}"
                               HorizontalOptions="Start" />
            <Label Text="{Binding HistoryNote}" Style="{StaticResource Caption}"
                   IsVisible="{Binding HistoryNote, Converter={StaticResource NotEmpty}}" />
            <GraphicsView x:Name="Chart" HeightRequest="180" IsVisible="{Binding HasChart}" />

            <!-- «Де купити» (T15/§17.5): той самий товар (mpn) у крамницях, від найдешевшої.
                 Видно лише коли є ≥2 крамниці — інакше блок не додає нічого. -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding HasOffers}" Margin="0,12,0,0">
                <Label Text="Де купити" Style="{StaticResource H2}" />
                <VerticalStackLayout Spacing="6" BindableLayout.ItemsSource="{Binding Offers}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:Offer">
                            <Border Style="{StaticResource Card}" Padding="14,12"
                                    StrokeShape="RoundRectangle 12"
                                    Opacity="{Binding Opacity}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.OpenOfferCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Store}" Style="{StaticResource Body}"
                                               FontAttributes="Bold" />
                                        <Label Text="Немає в наявності" Style="{StaticResource Caption}"
                                               FontSize="11"
                                               IsVisible="{Binding InStock, Converter={StaticResource Invert}}" />
                                    </VerticalStackLayout>
                                    <!-- ціна крамниці як згори картки: поточна + −% в рядок, стара перекреслена під ними -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="1" HorizontalOptions="End">
                                        <HorizontalStackLayout Spacing="6" HorizontalOptions="End">
                                            <Label Text="{Binding CurrentGrn}" Style="{StaticResource PriceMain}"
                                                   FontSize="16" VerticalOptions="Center" />
                                            <Border Style="{StaticResource PillDiscount}" Padding="5,2"
                                                    StrokeShape="RoundRectangle 6" VerticalOptions="Center"
                                                    IsVisible="{Binding HasPct}">
                                                <Label Text="{Binding PctText}" TextColor="White"
                                                       FontAttributes="Bold" FontSize="10" />
                                            </Border>
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding OldGrn}" Style="{StaticResource PriceOld}"
                                               HorizontalOptions="End" IsVisible="{Binding HasOld}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Button Text="Відкрити в крамниці" Command="{Binding OpenStoreCommand}"
                    Margin="0,12,0,0" HeightRequest="48" />

            <!-- «Стежити за ціною»: доступно лише залогіненим (список належить акаунту) -->
            <Button Text="{Binding WatchButtonText}" Command="{Binding WatchCommand}"
                    IsEnabled="{Binding WatchBusy, Converter={StaticResource Invert}}"
                    IsVisible="{Binding CanWatch}" HeightRequest="48"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={StaticResource BrandLight}, Dark={StaticResource BrandDark}}"
                    BorderColor="{AppThemeBinding Light={StaticResource BrandLight}, Dark={StaticResource BrandDark}}"
                    BorderWidth="1" />
            <Label Text="{Binding WatchNote}" FontSize="13" HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource BrandLight}, Dark={StaticResource BrandDark}}"
                   IsVisible="{Binding WatchNote, Converter={StaticResource NotEmpty}}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
