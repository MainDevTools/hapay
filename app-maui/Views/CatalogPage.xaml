<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Hapay.Views.CatalogPage"
    x:Name="Page"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Hapay.ViewModels"
    xmlns:models="clr-namespace:Hapay.Models"
    xmlns:conv="clr-namespace:Hapay.Converters"
    x:DataType="vm:CatalogViewModel"
    Title="Хапай">

    <ContentPage.Resources>
        <conv:StringNotEmptyConverter x:Key="NotEmpty" />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Акаунт" Command="{Binding AccountCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*" Padding="0">

        <VerticalStackLayout Grid.Row="0" Padding="12,8" Spacing="8">
            <SearchBar Placeholder="Пошук за назвою…" Text="{Binding SearchText}"
                       SearchCommand="{Binding SearchCommand}" />
            <Label Text="{Binding ErrorMessage}" TextColor="#E23B3B"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource NotEmpty}}" />
        </VerticalStackLayout>

        <RefreshView Grid.Row="1" IsRefreshing="{Binding IsRefreshing}" Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Groups}" IsGrouped="True">

                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2"
                                     HorizontalItemSpacing="10" VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>

                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="32" Spacing="8" VerticalOptions="Center">
                        <Label Text="Поки немає знижок" HorizontalOptions="Center"
                               FontAttributes="Bold" IsVisible="{Binding ShowEmpty}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <!-- «Популярні моделі»: товар у найбільшій к-сті крамниць → «від X ₴» -->
                <CollectionView.Header>
                    <VerticalStackLayout Spacing="6" Padding="0,4,0,6" IsVisible="{Binding HasPopular}">
                        <Label Text="Популярні моделі" FontSize="16" FontAttributes="Bold"
                               Padding="14,8,14,0" />
                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <HorizontalStackLayout Padding="14,0" Spacing="10"
                                                   BindableLayout.ItemsSource="{Binding Popular}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:Discount">
                                        <Border WidthRequest="132" StrokeThickness="0"
                                                StrokeShape="RoundRectangle 14" Padding="10"
                                                BackgroundColor="{AppThemeBinding Light=White, Dark=#191B1F}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={x:Reference Page}, Path=BindingContext.OpenProductCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="6">
                                                <Border HeightRequest="78" StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 10" Padding="4"
                                                        BackgroundColor="{AppThemeBinding Light=#F4F4F6, Dark=#22242A}">
                                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFit" />
                                                </Border>
                                                <Label Text="{Binding Title}" FontSize="12" MaxLines="2"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding PriceText}" FontAttributes="Bold" FontSize="14"
                                                       TextColor="{AppThemeBinding Light=#512BD4, Dark=#AC99EA}" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>
                </CollectionView.Header>

                <!-- заголовок розділу (Електроніка / Зоотовари) -->
                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate x:DataType="models:CategoryGroup">
                        <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold"
                               Padding="14,16,14,6" />
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>

                <!-- плитка категорії: фото товару-представника (емодзі — фолбек) + назва + к-сть -->
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Category">
                        <Grid Padding="6,0">
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{AppThemeBinding Light=White, Dark=#191B1F}"
                                    Padding="12" MinimumHeightRequest="140">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference Page}, Path=BindingContext.OpenCategoryCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="8">
                                    <Border HeightRequest="72" StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                            Padding="6" IsVisible="{Binding HasImage}"
                                            BackgroundColor="{AppThemeBinding Light=#F4F4F6, Dark=#22242A}">
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFit" />
                                    </Border>
                                    <Label Text="{Binding Icon}" FontSize="34" IsVisible="{Binding NoImage}" />
                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="14"
                                           MaxLines="2" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding CountText}" FontSize="12" TextColor="Gray" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <BoxView HeightRequest="16" Color="Transparent" />
                </CollectionView.Footer>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
