<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Hapay.Views.CatalogPage"
    x:Name="Page"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Hapay.ViewModels"
    xmlns:models="clr-namespace:Hapay.Models"
    xmlns:conv="clr-namespace:Hapay.Converters"
    x:DataType="vm:CatalogViewModel"
    Title="Хапай">

    <ContentPage.Resources>
        <conv:StringNotEmptyConverter x:Key="NotEmpty" />
    </ContentPage.Resources>

    <!-- Дії тулбара — іконками (Material: у top app bar дії саме значки, текст там
         нестандартний). Text лишаємо: Android бере його для overflow-меню й для
         підказки на довгий тап, тож доступність не втрачається. -->
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Стеження" Command="{Binding WatchlistCommand}"
                     IconImageSource="{AppThemeBinding Light=ic_watch_light.png, Dark=ic_watch_dark.png}" />
        <ToolbarItem Text="Акаунт" Command="{Binding AccountCommand}"
                     IconImageSource="{AppThemeBinding Light=ic_account_light.png, Dark=ic_account_dark.png}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*" Padding="0">

        <VerticalStackLayout Grid.Row="0" Padding="12,8" Spacing="8">
            <Border Style="{StaticResource FilterBar}">
                <SearchBar Placeholder="Пошук за назвою…" Text="{Binding SearchText}"
                           SearchCommand="{Binding SearchCommand}" />
            </Border>
            <Label Text="{Binding ErrorMessage}" Margin="4,0"
                   TextColor="{AppThemeBinding Light={StaticResource DiscountLight}, Dark={StaticResource DiscountDark}}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource NotEmpty}}" />
        </VerticalStackLayout>

        <RefreshView Grid.Row="1" IsRefreshing="{Binding IsRefreshing}" Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Groups}" IsGrouped="True">

                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2"
                                     HorizontalItemSpacing="10" VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>

                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="32" Spacing="8" VerticalOptions="Center">
                        <Label Text="Поки немає знижок" HorizontalOptions="Center"
                               FontAttributes="Bold" IsVisible="{Binding ShowEmpty}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <!-- «Популярні моделі»: товар у найбільшій к-сті крамниць → «від X ₴» -->
                <CollectionView.Header>
                    <VerticalStackLayout Spacing="8" Padding="0,4,0,6" IsVisible="{Binding HasPopular}">
                        <Label Text="Популярні моделі" Style="{StaticResource H2}"
                               Padding="16,8,16,0" />
                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <HorizontalStackLayout Padding="16,0" Spacing="10"
                                                   BindableLayout.ItemsSource="{Binding Popular}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:Discount">
                                        <Border WidthRequest="140" Style="{StaticResource Card}" Padding="10">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={x:Reference Page}, Path=BindingContext.OpenProductCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="8">
                                                <Border HeightRequest="86" Padding="8"
                                                        Style="{StaticResource Thumb}">
                                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFit" />
                                                </Border>
                                                <Label Text="{Binding Title}" Style="{StaticResource Caption}"
                                                       MaxLines="2" LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding PriceText}" FontAttributes="Bold" FontSize="14"
                                                       TextColor="{AppThemeBinding Light={StaticResource BrandLight}, Dark={StaticResource BrandDark}}" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>
                </CollectionView.Header>

                <!-- заголовок розділу (Електроніка / Зоотовари) -->
                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate x:DataType="models:CategoryGroup">
                        <Label Text="{Binding Title}" Style="{StaticResource H2}"
                               Padding="16,16,16,8" />
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>

                <!-- плитка категорії: фото товару-представника (емодзі — фолбек) + назва + к-сть -->
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Category">
                        <Grid Padding="6,0">
                            <Border Style="{StaticResource Card}" Padding="12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference Page}, Path=BindingContext.OpenCategoryCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <!-- Рядки фіксовані (86,Auto,Auto), а не Auto по фото: інакше
                                     плитки різної висоти й сітка «сходинками». Емодзі-фолбек
                                     живе в ТОМУ САМОМУ рядку, тож плитка без фото не коротша. -->
                                <Grid RowDefinitions="86,Auto,Auto" RowSpacing="8">
                                    <Border Grid.Row="0" Padding="6" Style="{StaticResource Thumb}"
                                            IsVisible="{Binding HasImage}">
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFit" />
                                    </Border>
                                    <Label Grid.Row="0" Text="{Binding Icon}" FontSize="40"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           IsVisible="{Binding NoImage}" />
                                    <Label Grid.Row="1" Text="{Binding Name}" Style="{StaticResource Body}"
                                           FontAttributes="Bold" MaxLines="2" LineBreakMode="TailTruncation" />
                                    <Label Grid.Row="2" Text="{Binding CountText}" Style="{StaticResource Caption}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <BoxView HeightRequest="16" Color="Transparent" />
                </CollectionView.Footer>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
