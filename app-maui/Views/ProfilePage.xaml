<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Hapay.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Hapay.ViewModels"
    xmlns:conv="clr-namespace:Hapay.Converters"
    x:DataType="vm:ProfileViewModel"
    Title="Профіль">

    <ContentPage.Resources>
        <conv:StringNotEmptyConverter x:Key="NotEmpty" />
    </ContentPage.Resources>

    <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Start">

        <Label Text="{Binding Email}" FontSize="18" FontAttributes="Bold" />
        <Label Text="{Binding RoleLabel}" TextColor="Gray" />

        <!-- збір: лише для колектора. Тягне HTML крамниць зі свого IP, парсить сервер (S11 етап 3) -->
        <VerticalStackLayout IsVisible="{Binding IsCollector}" Spacing="10">
            <Border Padding="12" StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#EEF6EC, Dark=#132A1D}"
                    StrokeShape="RoundRectangle 10">
                <Label Text="Ти колектор — збираєш ціни зі своєї мережі. Тисни, коли є Wi-Fi."
                       FontSize="13" />
            </Border>
            <!-- фоновий збір (T16): WorkManager кожні ~15 хв, лише Wi-Fi + зарядка -->
            <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding AutoCollectSupported}">
                <Label Text="Збирати автоматично (Wi-Fi + зарядка)"
                       VerticalOptions="Center" FontSize="14" />
                <Switch Grid.Column="1" IsToggled="{Binding AutoCollect}" />
            </Grid>
            <Label Text="{Binding TodayText}" FontSize="12" TextColor="Gray" />

            <Button Text="Зібрати ціни зараз" Command="{Binding CollectCommand}" HeightRequest="48" />
            <ActivityIndicator IsRunning="{Binding IsCollecting}" IsVisible="{Binding IsCollecting}"
                               HorizontalOptions="Center" />
            <Label Text="{Binding CollectStatus}" FontSize="13" TextColor="Gray"
                   IsVisible="{Binding CollectStatus, Converter={StaticResource NotEmpty}}" />
        </VerticalStackLayout>

        <BoxView HeightRequest="1" Color="#22808080" Margin="0,8" />

        <Button Text="Вийти" Command="{Binding LogoutCommand}"
                BackgroundColor="Transparent" TextColor="#E23B3B" HeightRequest="48" />
    </VerticalStackLayout>
</ContentPage>
