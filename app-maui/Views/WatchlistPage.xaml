<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Hapay.Views.WatchlistPage"
    x:Name="Page"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Hapay.ViewModels"
    xmlns:models="clr-namespace:Hapay.Models"
    xmlns:conv="clr-namespace:Hapay.Converters"
    x:DataType="vm:WatchlistViewModel"
    Title="Мої відстеження">

    <ContentPage.Resources>
        <conv:StringNotEmptyConverter x:Key="NotEmpty" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <Label Grid.Row="0" Text="{Binding ErrorMessage}" TextColor="{AppThemeBinding Light={StaticResource DiscountLight}, Dark={StaticResource DiscountDark}}" Padding="14,10"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource NotEmpty}}" />

        <RefreshView Grid.Row="1" IsRefreshing="{Binding IsRefreshing}" Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Items}">

                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="32" Spacing="10" VerticalOptions="Center"
                                         IsVisible="{Binding ShowEmpty}">
                        <Label Text="Поки нічого не відстежуєш" FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Відкрий товар і натисни «Стежити за ціною» — тут буде видно, як вона змінилась."
                               TextColor="{AppThemeBinding Light={StaticResource MutedLight}, Dark={StaticResource MutedDark}}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:WatchItem">
                        <Grid Padding="12,6">
                            <Border Style="{StaticResource Card}" Padding="12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference Page}, Path=BindingContext.OpenCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="74,*,Auto" ColumnSpacing="12">
                                    <Border Grid.Column="0" Style="{StaticResource Thumb}"
                                            WidthRequest="82" HeightRequest="82" Padding="6"
                                            VerticalOptions="Start">
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFit" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                                        <Label Text="{Binding Title}" MaxLines="2"
                                               LineBreakMode="TailTruncation" FontAttributes="Bold" />
                                        <Label Text="{Binding StoresText}" FontSize="12" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource BrandLight}, Dark={StaticResource BrandDark}}"
                                               IsVisible="{Binding HasMultiStores}" />
                                        <Label Text="{Binding CurrentGrn}" FontAttributes="Bold" FontSize="17" />
                                        <!-- рух ціни показуємо ЛИШЕ коли є з чим порівняти -->
                                        <Label Text="{Binding DeltaText}" FontSize="12"
                                               TextColor="{Binding DeltaColor}"
                                               IsVisible="{Binding HasDelta}" />
                                        <Label Text="{Binding SinceText}" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource MutedLight}, Dark={StaticResource MutedDark}}" />
                                    </VerticalStackLayout>

                                    <Button Grid.Column="2" Text="✕" WidthRequest="40" HeightRequest="40"
                                            Padding="0" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light={StaticResource MutedLight}, Dark={StaticResource MutedDark}}"
                                            VerticalOptions="Start"
                                            Command="{Binding Source={x:Reference Page}, Path=BindingContext.RemoveCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
