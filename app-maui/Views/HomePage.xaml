<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Hapay.Views.HomePage"
    x:Name="Page"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Hapay.ViewModels"
    xmlns:models="clr-namespace:Hapay.Models"
    xmlns:conv="clr-namespace:Hapay.Converters"
    x:DataType="vm:HomeViewModel"
    Title="{Binding PageTitle}">

    <ContentPage.Resources>
        <conv:StringNotEmptyConverter x:Key="NotEmpty" />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Акаунт" Command="{Binding AccountCommand}"
                     IconImageSource="{AppThemeBinding Light=ic_account_light.png, Dark=ic_account_dark.png}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*" Padding="0">

        <!-- панель: пошук + категорія (повна ширина — найдовші підписи, без обрізання) + сорт|ціна -->
        <!-- Панель свідомо в ДВА рядки, не в чотири: раніше фільтри з'їдали ~38% першого
             екрана, і людина, яка відкрила категорію подивитись товари, бачила панель
             керування. Категорія тепер в одному рядку з сортуванням і ціною — назву
             обраної категорії й так видно в заголовку сторінки. -->
        <VerticalStackLayout Grid.Row="0" Padding="12,8" Spacing="8">
            <Border Style="{StaticResource FilterBar}">
                <VerticalStackLayout Spacing="2">
                    <SearchBar Placeholder="Пошук за назвою…" Text="{Binding SearchText}" />
                    <!-- Ширини нерівні свідомо: назви категорій найдовші («Ноутбуки та
                         ПК (933)»), підписи ціни найкоротші («Будь-яка»). При рівних
                         третинах категорію різало просто на лічильнику. -->
                    <Grid ColumnDefinitions="1.35*,*,0.8*" ColumnSpacing="6">
                        <Picker Grid.Column="0" Title="Категорія" FontSize="13"
                                ItemsSource="{Binding Categories}"
                                ItemDisplayBinding="{Binding Display}"
                                SelectedItem="{Binding SelectedCategory}" />
                        <Picker Grid.Column="1" Title="Сортування" FontSize="13"
                                ItemsSource="{Binding SortOptions}"
                                ItemDisplayBinding="{Binding Label}"
                                SelectedItem="{Binding SelectedSort}" />
                        <Picker Grid.Column="2" Title="Ціна" FontSize="13"
                                ItemsSource="{Binding PriceOptions}"
                                ItemDisplayBinding="{Binding Label}"
                                SelectedItem="{Binding SelectedPrice}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
            <!-- у пошуку правила інші, ніж при гортанні — кажемо це прямо -->
            <Label Text="Пошук — по всьому каталогу, не лише знижки"
                   Style="{StaticResource Caption}" Margin="4,0"
                   IsVisible="{Binding IsSearching}" />
            <!-- і окремо: чому видача вийшла за межі обраної категорії -->
            <Label Text="{Binding SearchNote}" FontSize="12" Margin="4,0"
                   TextColor="{AppThemeBinding Light={StaticResource BrandLight}, Dark={StaticResource BrandDark}}"
                   IsVisible="{Binding SearchNote, Converter={StaticResource NotEmpty}}" />
            <Label Text="{Binding ErrorMessage}" Margin="4,0"
                   TextColor="{AppThemeBinding Light={StaticResource DiscountLight}, Dark={StaticResource DiscountDark}}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource NotEmpty}}" />
        </VerticalStackLayout>

        <!-- стрічка -->
        <RefreshView Grid.Row="1" IsRefreshing="{Binding IsRefreshing}" Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Items}"
                            RemainingItemsThreshold="5"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">

                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="32" Spacing="8" VerticalOptions="Center">
                        <Label Text="Нічого не знайдено" HorizontalOptions="Center"
                               FontAttributes="Bold" IsVisible="{Binding ShowEmpty}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Discount">
                        <Grid Padding="12,4">
                            <Border Style="{StaticResource Card}" Padding="10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference Page}, Path=BindingContext.GoToDetailCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="72,*" ColumnSpacing="10">
                                    <!-- фото в рамці з фоном: биті/відсутні картинки не виглядають дірою -->
                                    <Border Grid.Column="0" Style="{StaticResource Thumb}"
                                            WidthRequest="72" HeightRequest="72" Padding="4"
                                            VerticalOptions="Start">
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFit" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                                        <Label Text="{Binding Title}" MaxLines="2" LineBreakMode="TailTruncation"
                                               Style="{StaticResource Body}" FontAttributes="Bold" />
                                        <!-- одна крамниця → її назва; група → «в N крамницях» без однієї назви -->
                                        <Label Text="{Binding SubTitle}" Style="{StaticResource Caption}"
                                               IsVisible="{Binding ShowStoreLine}" />
                                        <Label Text="{Binding StoresText}" Style="{StaticResource Caption}"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource BrandLight}, Dark={StaticResource BrandDark}}"
                                               IsVisible="{Binding HasMultiStores}" />
                                        <!-- Дата акції — нейтральним, а не червоним: червоне лишаємо ЛИШЕ
                                             пігулці −N%. Раніше на картці було дві червоні плями, і в
                                             стовпчику з п'яти карток око не мало за що зачепитись. -->
                                        <Label Text="{Binding PromoText}" Style="{StaticResource Caption}"
                                               FontSize="11" IsVisible="{Binding HasPromo}" />
                                        <!-- Ціна, стара ціна й −% — ОДНА думка, тож стоять поруч зліва.
                                             Раніше бейдж був притиснутий до правого краю (колонка «*»
                                             між ними), і око мусило стрибати через усю ширину картки,
                                             щоб зібрати «22 999 замість 42 999, це −47%». Порядок
                                             читання й ієрархія розмірів (18 → 12) роблять решту. -->
                                        <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="7"
                                              Margin="0,2,0,0">
                                            <Label Grid.Column="0" Text="{Binding PriceText}"
                                                   Style="{StaticResource PriceMain}" VerticalOptions="End" />
                                            <Label Grid.Column="1" Text="{Binding OldGrn}"
                                                   Style="{StaticResource PriceOld}"
                                                   VerticalOptions="End" IsVisible="{Binding HasOld}" />
                                            <Border Grid.Column="2" Style="{StaticResource PillDiscount}"
                                                    IsVisible="{Binding HasPct}" VerticalOptions="End">
                                                <Label Text="{Binding PctText}" TextColor="White"
                                                       FontAttributes="Bold" FontSize="11" />
                                            </Border>
                                        </Grid>
                                        <!-- «Дешевше в Rozetka на 6 887 ₴» — визнання, що НАША
                                             показана знижка не найкраща ціна. Незручно, але це
                                             буквально суть «Хапая». Зелена пігулка, а не сірий
                                             підпис: рядок рідкісний (~2% карток) і сірим губився б;
                                             колір інший, ніж у −% (червоний), щоб не зливалися. -->
                                        <Border IsVisible="{Binding HasCheaper}" Margin="0,4,0,0"
                                                HorizontalOptions="Start" Style="{StaticResource PillSave}">
                                            <Label Text="{Binding CheaperText}" FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource SaveFgLight}, Dark={StaticResource SaveFgDark}}" />
                                        </Border>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                                       Margin="0,16" HorizontalOptions="Center" />
                </CollectionView.Footer>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
