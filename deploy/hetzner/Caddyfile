# Caddy сам отримує й оновлює сертифікат Let's Encrypt — тому домен, а не голий IP:
# сертифікат видають на імʼя. Плюс домен дає змінити хост, не ламаючи вже встановлені
# застосунки (інакше — оновлення в сторі й цикл рев'ю Apple заради зміни адреси).
#
# {$HAPAY_DOMAIN} підставляється з /etc/hapay/hapay.env (drop-in EnvironmentFile у caddy.service)

{$HAPAY_DOMAIN} {
	encode gzip zstd

	# Mini App вантажиться в iframe Telegram — інакше порожній екран.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "frame-ancestors https://web.telegram.org https://*.telegram.org"
		-Server
	}

	reverse_proxy 127.0.0.1:8080 {
		health_uri /api/health
		health_interval 30s
	}

	log {
		# bare-metal: /var/log/caddy існує з прав caddy:caddy (створює deb-пакет).
		# Було /data/access.log з Docker-версії — на хості /data нема, і Caddy ВАЛИВСЯ на старті.
		output file /var/log/caddy/hapay-access.log {
			roll_size 10mb
			roll_keep 5
		}
		# initData містить дані користувача Telegram — у логах їм не місце (§7.7)
		format filter {
			wrap json
			fields {
				request>headers>X-Init-Data delete
				request>headers>Cookie delete
			}
		}
	}
}
